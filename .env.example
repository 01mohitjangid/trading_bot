# Binance USDT-M Futures Testnet credentials.
# Generate them at https://testnet.binancefuture.com (API Key management).
# Copy this file to `.env` and fill in your real keys — `.env` is gitignored.
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Base URL — defaults to the testnet; override only if you know why.
BINANCE_BASE_URL=https://testnet.binancefuture.com

# Optional tuning
BINANCE_RECV_WINDOW=5000
HTTP_TIMEOUT=10
LOG_DIR=logs
LOG_LEVEL=INFO
